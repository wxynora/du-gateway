# 复制为 .env 并填写，勿提交 .env

# AI 转发目标（助手端）；支持多目标 fallback，第一个失败自动试下一个
TARGET_AI_URL=https://api.example.com/v1/chat/completions
TARGET_AI_API_KEY=
# 多目标（可选）：逗号分隔 URL，与下面 KEY 一一对应；不填则只用上面一个
# TARGET_AI_URLS=https://api1.com/v1/chat/completions,https://api2.com/v1/chat/completions
# TARGET_AI_API_KEYS=key1,key2
# 本地测试脚本 scripts/call_test.py 用的模型（你的 API 只支持特定模型时必填，例如 claude-3-5-sonnet）
# CALL_TEST_MODEL=
# RikkaHub 显示模型列表：若上游没有 /v1/models 或拉取失败，用此兜底（逗号分隔模型 id）
# GATEWAY_MODELS=gpt-4,gpt-4o,claude-3-5-sonnet
# 网关侧默认模型：请求没带 model 时自动补这个（留空则用 GATEWAY_MODELS 第一个，再否则 gpt-4）
# DEFAULT_CHAT_MODEL=claude-3-5-sonnet
# 网关侧强制模型：1=无论请求传什么都覆盖成 DEFAULT_CHAT_MODEL（或回退值）
# FORCE_CHAT_MODEL_ENABLED=0

# DeepSeek：用于每 4 轮窗口总结
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=

# 动态层向量检索（可选，未配置会自动降级为关键词匹配）
# Cloudflare Workers AI embeddings（推荐：中文优先 + 成本低）
CF_ACCOUNT_ID=
# Cloudflare API Token（创建时给 Workers AI / AI Run 相关权限；具体名称以控制台为准）
CLOUDFLARE_API_TOKEN=
# embedding 模型（默认中文推荐：@cf/baai/bge-m3）
CF_EMBEDDING_MODEL=@cf/baai/bge-m3
# pooling：cls 更准，但与 mean 产生的向量不兼容；上线后不要随便切
CF_EMBEDDING_POOLING=cls
# embedding 缓存（内存，单进程）
EMBED_CACHE_TTL_SECONDS=3600
EMBED_CACHE_MAX_ITEMS=1024

# 便宜图像描述 AI（可选，用于图片转文字存 R2）
IMAGE_DESC_API_URL=
IMAGE_DESC_API_KEY=
# 图片转描述用的模型名（默认 gpt-4o-mini）
IMAGE_DESC_MODEL=gpt-4o-mini

# 天气 API（渡查天气工具用）
WEATHER_API_URL=
WEATHER_API_KEY=
# 黄历 API（渡查黄历/宜忌工具用）
ALMANAC_API_URL=
ALMANAC_API_KEY=

# WebSearch（Phase1：仅搜索，不抓取）
# WEBSEARCH_ENABLED=1
# provider 顺序：逗号分隔，默认 tavily
# WEBSEARCH_PROVIDER_ORDER=tavily
# Tavily
# TAVILY_API_KEY=
# TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
# 通用参数
# WEBSEARCH_TIMEOUT_SECONDS=8
# WEBSEARCH_MAX_RESULTS=5
# Phase2：抓取解析（轻量）
# WEBSEARCH_FETCH_ENABLED=1
# WEBSEARCH_FETCH_TOP_K=2
# WEBSEARCH_MAX_PAGE_CHARS=12000

# Cloudflare R2（S3 兼容）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=du-gateway
R2_PUBLIC_URL=

# Notion
NOTION_API_KEY=
NOTION_VERSION=2022-06-28
# 渡 Notion 工具（NOTION_TOOLS_ENABLED=1）：核心缓存待审、交换日记、日程本 Database ID（填了才注入对应工具）
# NOTION_CORE_CACHE_DATABASE_ID=
# NOTION_EXCHANGE_DIARY_DATABASE_ID=
# NOTION_SCHEDULE_DATABASE_ID=

# 白名单：最多保留窗口数；超过 N 天未出现也踢出
MAX_WHITELIST_SIZE=50
WHITELIST_EXPIRE_DAYS=14

# Telegram Bot（示例：公网网关地址）
# TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 文游专用 GM Bot（可选）：与主 Bot 分开时在 @BotFather 再建一个 Bot，填其 Token；Webhook 需单独设为 …/telegram/webhook_gm
# TELEGRAM_GM_BOT_TOKEN=
# TELEGRAM_GATEWAY_URL=https://duxy-home.com
# Telegram Webhook（可选）：建议配置一个随机串，用于校验 Telegram 请求头
# TELEGRAM_WEBHOOK_SECRET=change_me_to_a_long_random_string
# 文游（跑团）：固定群 chat_id（仅该群内使用 /story /go /end；0=关闭）
# WENYOU_GROUP_CHAT_ID=-1001234567890
# 可选：只认你的 Telegram user id（留空则与 TELEGRAM_PROACTIVE_TARGET_USER_ID 相同）
# TELEGRAM_WENYOU_OWNER_USER_ID=123456789
# 文游 GM 模型（DeepSeek）
# WENYOU_DS_MODEL=deepseek-chat
# 文游：无 /save /load；积分用于复活、系统商店（道具/血统/体力智慧）、主神空间治疗；等级与阶位 D～S、状态见【主神面板】与固定页脚

# Rikka 等前端预设：要从内容中移除的短语（逗号分隔，留空则不删）
RIKKA_PRESET_PATTERNS=

# 失败对话初筛：回复低于此长度不存档（字）
FAILED_RESPONSE_MIN_LENGTH=10
# 失败对话初筛：包含任一词不存档（逗号分隔，小写匹配）
FAILED_RESPONSE_ERROR_KEYWORDS=error,出错,失败,超时,抱歉，我无法

# 动态层注入：取 Top N 条记忆注入 system（建议 5–10）
DYNAMIC_MEMORY_TOP_N=3

# 记忆注入 token 上限（总结+动态层合计，建议 2500–4000）
MEMORY_INJECTION_MAX_TOKENS=3000
# 总结占比（余下为动态层）
MEMORY_SUMMARY_TOKEN_RATIO=0.6
# 请求总字符上限（0=不限制）。超限时删最老对话轮次，避免上游截断。50K token 约 10 万字符
# MAX_REQUEST_CHARS=100000
# 转发时若请求未带 max_tokens 或小于此值则设为该值，避免回复被截断（0=不强制，默认 8192）
# MAX_COMPLETION_TOKENS=8192
# 流式转发读超时（秒），思维链模型思考久时可调大，默认 300
# STREAM_TIMEOUT_SECONDS=300

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 电脑控制队列 token（/api/pc_command* 鉴权用）
# PC_COMMAND_TOKEN=请替换成强随机字符串

# HTML 临时预览（POST /html-preview/ 鉴权；GET /html-preview/v/<token> 公开，token 需保密）
# HTML_PREVIEW_SECRET=请替换成强随机字符串
# HTML_PREVIEW_TTL_SECONDS=7200
# HTML_PREVIEW_MAX_BYTES=2097152
# HTML_PREVIEW_MAX_ITEMS=200
# 手机能打开的公网根（https://域名，无路径尾斜杠）。预览链接与渡工具必用其一，勿填 127.0.0.1
# GATEWAY_PUBLIC_BASE_URL=https://你的域名
# 仅预览用可单独写（优先于上一项）：HTML_PREVIEW_PUBLIC_BASE_URL=https://你的域名
# 渡调用工具 publish_html_preview（默认开启，可关）
# HTML_PREVIEW_TOOL_ENABLED=1

# [PCMD:open:xxx] 允许的应用名（逗号分隔，小写）
# PC_OPEN_APP_ALLOWLIST=notepad,chrome,vscode,wechat,notion
# [PCMD:url:https://...] 允许的域名（逗号分隔）
# PC_URL_DOMAIN_ALLOWLIST=github.com,bilibili.com,openai.com,notion.so

# “老婆隔多久回我”的提示：超过阈值才注入（分钟）
REPLY_GAP_THRESHOLD_MINUTES=30

# 服务（HOST=0.0.0.0 才能被公网/局域网访问；若写 127.0.0.1 则仅本机可访问）
FLASK_ENV=development
HOST=0.0.0.0
PORT=5000

# Telegram Bot（见 docs/主动发消息与Telegram完整方案.md）
# TELEGRAM_BOT_TOKEN=   # Bot Token（@BotFather 创建）
# TELEGRAM_GATEWAY_URL=http://127.0.0.1:5000   # Bot 调网关的 base URL（同机可 127.0.0.1，异机填公网）
# TELEGRAM_CHAT_PATH=/v1/chat/completions
# TELEGRAM_CHAT_MODEL=   # 可选，留空用 GATEWAY_MODELS 第一个或 gpt-4

# Telegram 体验参数（可选）
# TELEGRAM_INPUT_IDLE_SECONDS=15          # 停止输入多少秒后合并提交（输入聚合）
# TELEGRAM_INPUT_IMMEDIATE_CHARS=200      # 单条超过多少字符则立即提交
# TELEGRAM_OUTPUT_CHUNK_CHARS=100         # 输出每条最大字符数（<=4096）
# TELEGRAM_OUTPUT_SEND_DELAY_MIN_SECONDS=0.4   # 输出分条间隔下限（秒）
# TELEGRAM_OUTPUT_SEND_DELAY_MAX_SECONDS=1.0   # 输出分条间隔上限（秒）
# TELEGRAM_CONTEXT_LAST_TURNS=4           # 上下文缓存：携带最近 N 轮（user+assistant）给渡

# Telegram 主动发消息（调度器，可选）
# TELEGRAM_PROACTIVE_ENABLED=1
# TELEGRAM_PROACTIVE_TARGET_USER_ID=8260066512     # 你的 telegram_user_id（看 bot 日志 user_id=...）
# TELEGRAM_PROACTIVE_INTERVAL_MINUTES=30
# TELEGRAM_PROACTIVE_QUIET_START_HM=00:00
# TELEGRAM_PROACTIVE_QUIET_END_HM=07:30
# TELEGRAM_PROACTIVE_BASE_P=0.05
# TELEGRAM_PROACTIVE_K_PER_HOUR=0.03
# TELEGRAM_PROACTIVE_PROB_MULTIPLIER=2.0   # 概率整体倍率：不改调度间隔，只增强“命中后发消息”的可能性
# TELEGRAM_PROACTIVE_NO_CONTACT_TOKEN=NO_CONTACT
# TELEGRAM_PROACTIVE_SKIP_IF_ACTIVE_MINUTES=30   # 用户在此分钟数内发过消息则不主动发（正在聊天时不打扰）

# MiniMax TTS（可选，用于 Telegram 语音回复）
# MINIMAX_API_KEY=xxxx
# MINIMAX_T2A_URL=https://api.minimaxi.com/v1/t2a_v2
# MINIMAX_T2A_MODEL=speech-2.8-hd
# MINIMAX_VOICE_ID=du_123456
# MINIMAX_VOICE_SPEED=1
# MINIMAX_VOICE_VOL=1
# MINIMAX_VOICE_PITCH=0
# MINIMAX_VOICE_EMOTION=happy
# MINIMAX_AUDIO_SAMPLE_RATE=32000
# MINIMAX_AUDIO_BITRATE=128000
# MINIMAX_AUDIO_FORMAT=mp3
# MINIMAX_AUDIO_CHANNEL=1
# TELEGRAM_VOICE_REPLY_ENABLED=1

# MCP（论坛 HTTP 工具，建议放在网关统一调用）
# MCP_ENABLED=1
# MCP_AUTH_MODE=token               # token / token_ip / off（仅内网调试）
# MCP_TOKENS=replace_me_with_long_random_token_32_to_64_chars
# MCP_FORUM_BASE_URL=https://forum.example.com
# MCP_FORUM_ALLOWED_HOSTS=forum.example.com,https://api.forum.example.com
# （可写纯域名或完整 URL，会自动提取 hostname；不要带多余空格）
# MCP_IP_ALLOWLIST=1.2.3.4/32       # 仅 MCP_AUTH_MODE=token_ip 时启用
# MCP_TRUST_PROXY=true              # 反代后获取真实客户端 IP
# MCP_HTTP_TIMEOUT_SECONDS=20
# MCP_HTTP_MAX_TIMEOUT_SECONDS=60
# MCP_HTTP_RETRIES=2
# MCP_HTTP_MAX_RESPONSE_CHARS=12000
# MCP_FORUM_DEFAULT_UID=your_uid_here
# MCP_FORUM_VERIFY_UID_PATH=/verify-uid
# MCP_FORUM_REGISTER_PATH=/register
# MCP_FORUM_POST_CREATE_PATH=/posts
# MCP_FORUM_POST_LIST_PATH=/posts
# MCP_FORUM_POST_DETAIL_PATH_TEMPLATE=/posts/{post_id}
# MCP_FORUM_COMMENT_CREATE_PATH_TEMPLATE=/posts/{post_id}/comments
# MCP_FORUM_VERIFY_UID_METHOD=GET
# MCP_FORUM_REGISTER_METHOD=POST
# MCP_FORUM_VERIFY_UID_PATHS=/verify-uid,/api/verify-uid,/verify_uid,/api/verify_uid
# MCP_FORUM_POST_LIST_PATHS=/posts,/api/posts,/forum/posts,/api/v1/posts
