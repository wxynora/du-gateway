{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wenyou Evolution Routes",
  "type": "object",
  "required": ["schema_version", "routes"],
  "properties": {
    "schema_version": { "type": "integer" },
    "source": { "type": "string" },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "tags", "attrs"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "attrs": { "type": "object" },
          "hp_ratio": { "type": "number" },
          "san_ratio": { "type": "number" },
          "pollution": { "type": "integer", "minimum": 0 },
          "desc": { "type": "string" }
        }
      }
    }
  }
}
