# 小米账号。不要提交真实 .env。
XIAOMI_USER_ID=
XIAOMI_PASSWORD=
# 如果账号登录触发安全验证，可以改用 passToken；有 passToken 时可不填 password。
XIAOMI_PASS_TOKEN=

# 米家/小爱 App 里显示的音箱名称。
XIAOAI_DID=卧室小爱
XIAOAI_SPEAKER=卧室小爱

# du-gateway 公网地址。小爱播放 audio_url 也必须能访问这个域名。
DU_GATEWAY_URL=https://你的网关域名
# 可选：只有 du-gateway/.env 配了同名值才需要填；当前没配就留空。
XIAOAI_GATEWAY_TOKEN=
# 可选：不填时 du-gateway 会按 TELEGRAM_PROACTIVE_TARGET_USER_ID 推断 tg_窗口。
DU_WINDOW_ID=

# runner 标识，显示在 MiniApp 工具页连接状态里。
XIAOAI_RUNNER_NAME=mac-docker

# 轮询/会话参数。
XIAOAI_HEARTBEAT_MS=1000
XIAOAI_CONFIG_REFRESH_MS=30000
XIAOAI_ACTION_POLL_MS=5000
XIAOAI_ACTION_CLAIM_WAIT_SECONDS=12
XIAOAI_ACTION_CLAIM_TIMEOUT_MS=22000
XIAOAI_SESSION_TTL_SECONDS=60
XIAOAI_DEDUP_TTL_MS=10000
# 入口静音没读到原音量时，播放渡之前恢复到这个音量。
XIAOAI_MUTE_RESTORE_FALLBACK_VOLUME=35
XIAOAI_MUTE_VOLUME_READ_TIMEOUT_MS=250

# URL 播放策略。默认 auto：L05C 等型号走 player_play_music，其他型号先试直 URL。
# 不要固定 XIAOAI_PLAY_MUSIC_AUDIO_ID；默认会按每条 URL 生成临时 audio_id，避免撞到小米曲库。
XIAOAI_PLAY_URL_STRATEGY=auto
# XIAOAI_PLAY_MUSIC_AUDIO_ID=
