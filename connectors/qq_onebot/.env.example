# 连接器监听端口（NapCat/OneBot 事件上报到这里）
QQ_ONEBOT_PORT=8092

# 入站事件校验 token（可选；若配置，要求 NapCat 上报时带 Bearer）
QQ_ONEBOT_ACCESS_TOKEN=

# NapCat / OneBot HTTP API 基地址
QQ_ONEBOT_API_BASE=http://127.0.0.1:3000

# 调用 OneBot API 的 token（可选）
QQ_ONEBOT_API_TOKEN=

# 网关地址
GATEWAY_BASE_URL=http://127.0.0.1:5000
GATEWAY_CHAT_PATH=/v1/chat/completions

# 可选：强制指定模型；留空则自动取网关第一个模型
GATEWAY_MODEL=

# 沿用 Telegram 那套“用户输入”标记
GATEWAY_TG_USER_INPUT=1

# 输入聚合
QQ_INPUT_IDLE_SECONDS=15
QQ_INPUT_IMMEDIATE_CHARS=200

# 群聊 @ 时带入前面多少条群消息
QQ_GROUP_CONTEXT_MESSAGES=10
QQ_GROUP_HISTORY_KEEP_MESSAGES=50

# 输出切分
QQ_OUTPUT_CHUNK_CHARS=200
QQ_MAX_REPLY_TOTAL_CHARS=0
QQ_OUTPUT_SEND_DELAY_MS=400
