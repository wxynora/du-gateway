# iLink 基础域名（一般不用改）
ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# 本地状态文件（保存 bot_token 与 get_updates_buf 游标）
WECHAT_ILINK_STATE_FILE=.wechat_ilink_state.json

# 连接器是否启用（预留）
WECHAT_ILINK_ENABLED=1

# 网关地址（建议同机部署用 127.0.0.1）
GATEWAY_BASE_URL=http://127.0.0.1:5000
GATEWAY_CHAT_PATH=/v1/chat/completions

# 可选：强制指定模型；留空则交给网关自己补默认模型
GATEWAY_MODEL=

# 是否给网关打“这是用户输入”的标记（复用 Telegram 的注入策略）
GATEWAY_TG_USER_INPUT=1

# 输入聚合：用户停止输入多少秒后才提交到网关（参考 Telegram，默认 15 秒）
WECHAT_INPUT_IDLE_SECONDS=15
# 输入聚合：单条消息超过多少字符则立即提交（参考 Telegram，默认 200）
WECHAT_INPUT_IMMEDIATE_CHARS=200

# 上下文缓存：每次请求网关时携带最近 N 轮（user+assistant=一轮两条消息），默认 4（对齐 Telegram）
WECHAT_CONTEXT_LAST_TURNS=4

# 输出切分：按“换行优先 + 单段最多 N 字符”（默认 100）
WECHAT_OUTPUT_CHUNK_CHARS=200

# 单次回复总字符上限（0=不限制；默认不限制，避免“看起来被截断”）
WECHAT_MAX_REPLY_TOTAL_CHARS=0

# 发送节流：每段发送间隔（毫秒），避免 iLink 限频导致 ret=-2
WECHAT_OUTPUT_SEND_DELAY_MS=600

# 发送失败重试：仅对 ret=-2 这类可恢复错误重试一次（毫秒）
WECHAT_OUTPUT_RETRY_DELAY_MS=1200

# 微信“正在输入中”提示（iLink sendtyping）
WECHAT_TYPING_ENABLED=1
# 首次延迟发送（毫秒）
WECHAT_TYPING_FIRST_DELAY_MS=1000
# 后续心跳间隔（毫秒）
WECHAT_TYPING_INTERVAL_MS=4000
# 单次请求最多发送几次 typing（避免过多请求）
WECHAT_TYPING_MAX_SIGNALS=3
