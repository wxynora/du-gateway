# iLink 基础域名（一般不用改）
ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# 本地状态文件（保存 bot_token 与 get_updates_buf 游标）
WECHAT_ILINK_STATE_FILE=.wechat_ilink_state.json

# 网关地址（建议同机部署用 127.0.0.1）
GATEWAY_BASE_URL=http://127.0.0.1:5000
GATEWAY_CHAT_PATH=/v1/chat/completions

# 可选：强制指定模型；留空则交给网关自己补默认模型
GATEWAY_MODEL=

# 回复分段长度（避免微信侧单条太长发不出去；按需调小/调大）
WECHAT_MAX_REPLY_CHARS=800

# iLink 基础域名（一般不用改）
ILINK_BASE_URL=https://ilinkai.weixin.qq.com

# 本地状态文件（保存 bot_token 与 get_updates_buf 游标）
WECHAT_ILINK_STATE_FILE=.wechat_ilink_state.json

# 连接器是否启用（预留）
WECHAT_ILINK_ENABLED=1

# 网关地址（建议同机部署用 127.0.0.1）
GATEWAY_BASE_URL=http://127.0.0.1:5000
GATEWAY_CHAT_PATH=/v1/chat/completions

# 可选：强制指定模型；留空则交给网关自己补默认模型
GATEWAY_MODEL=

# 可选：是否给网关打“这是用户输入”的标记（用于 summary 注入策略）
GATEWAY_TG_USER_INPUT=0

# 回复分段长度（避免微信侧单条太长发不出去；按需调小/调大）
WECHAT_MAX_REPLY_CHARS=800

