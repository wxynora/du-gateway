node_modules/
*.log

# dist/ 故意入库：提供「构建后可运行版本」，试玩环境零安装即可 node farm-cli.mjs
dist/*.map

# 运行时存档（本地状态，不入库）
data/*.json
!data/.gitkeep
farm_save.json
ugc_save.json
codex-report.md
