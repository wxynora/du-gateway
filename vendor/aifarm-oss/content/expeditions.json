        "copper_echo"
      ],
      "finale": "rust_dragon"
    },
    {
      "id": "stardust_theater",
      "name": "星沙剧场",
      "theme": "一座废弃多年的老天文台，不知被谁改成了露天剧场。穹顶裂开一道缝，白天漏光、晚上漏星，舞台上的沙子会随着\"演出\"自己流动、塑形。这里的\"居民\"是一群戴着面具的旧戏偶，它们不演戏时就歪在座位上打盹，醒了就非拉着路过的人上台。　神秘 + 温柔 + 旧物感伤，像一场没人看但依然认真演完的午夜戏。不恐怖，但有点薄薄的怅惘。",
      "intro": "",
      "unlock": null,
      "events": [
        "dusty_ticket",
        "rehearsing_puppet",
        "grumpy_prompter",
        "starlight_crack",
        "talking_script",
        "old_dressing_case",
        "star_sand_curtain",
        "mask_wall",
        "curtain_tangle",
        "lost_prompter",
        "observatory_tea",
        "mirror_behind_curtain",
        "moon_phase_giant",
        "after_the_show",
        "sand_program"
      ],
      "finale": "moon_phase_giant"
    },
    {
      "id": "tidal_corridor",
      "name": "潮汐回廊",
      "theme": "一片被遗忘的海蚀洞穴群，潮水每日涨落两次，退潮时露出一条条湿漉漉的石廊，廊壁上嵌满不知谁留下的瓷片、铜铃和玻璃浮球，叮叮当当响个不停。洞里有会说话的海葵、贩卖旧物的寄居蟹商贩，和一间只在退潮时开张的茶馆。　神秘+温柔+一点咸湿的怀旧感，不恐怖，像一场潮乎乎的梦。",
      "intro": "",
      "unlock": null,
      "events": [
        "humming_shell",
        "porcelain_chime",
        "silver_scales",
        "salt_crystal",
        "low_tide_teahouse",
