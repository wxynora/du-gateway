{
  "maps": [
    {
      "id": "mushroom_forest",
      "name": "幻菇林",
      "theme": "终年浮着甜腥孢子的雾林，光线昏绿，脚下是层层叠叠的菌毯。越往深处雾越浓、蘑菇越大越古怪，住着半植物半灵性的菌类生灵，也有迷路的旅人和小动物。误食某些菇会看见不存在的东西。",
      "intro": "",
      "unlock": null,
      "events": [
        "spore_fountain",
        "talking_cap",
        "wrong_mushroom",
        "mycelium_hammock",
        "snail_courier",
        "weeping_spore_nest",
        "mushroom_wall",
        "scale_feather_chick",
        "mushroom_lantern_maker",
        "mask_mushrooms",
        "giant_in_the_mist",
        "spore_rain",
        "letter_in_mycelium",
        "wardens_footprints"
      ],
      "finale": "giant_in_the_mist"
    },
    {
      "id": "rusty_clocktown",
      "name": "锈钟古镇",
      "theme": "一座被时间遗忘的山间小镇，所有钟表都停在下午三点十七分。青铜路牌爬满铜绿，喷泉里流出温热的锈色泉水，居民是一群和善却健忘的老人——他们总说自己“好像丢了什么”，但不记得丢了什么。　神秘 + 童话 + 一缕温柔的哀愁。像午睡醒来发现黄昏已至，说不上难过，只是恍惚。",
      "intro": "",
      "unlock": null,
      "events": [
        "stopped_clocktower",
        "fountain_copper",
        "bakery_memory",
        "talking_statue",
