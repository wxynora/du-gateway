{
  "name": "aifarm",
  "version": "0.1.0",
  "description": "AI 农场联网小游戏 —— AI 自主种植养殖，玩家可联网偷菜/浇水",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "test:smoke": "npm run build && node tools/smoke-test.mjs",
    "parity": "node tools/parity-check.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run typecheck && npm run parity && npm run test:smoke"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
